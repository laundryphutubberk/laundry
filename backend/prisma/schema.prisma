// Laundry Operations & Linen Asset Management Platform
// schema.prisma v1.0
//
// Purpose:
// - Source of Truth for the Laundry Pilot Project.
// - Supports Laundry Workspace and Resort Workspace.
// - Supports lean production flow.
// - Supports linen inventory visibility.
// - Supports machine load planning with owner-defined load standards.
//
// Core principles:
// - Laundry Work is the operational center.
// - Bag is the intake unit.
// - Count Line is the real item count captured at laundry.
// - Inventory Summary is derived from movement history.
// - Resort Workspace must be isolated by resortId.
// - Issues must be explicit.
// - Machine load standards are defined by laundry owner.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  LAUNDRY_OWNER
  LAUNDRY_MANAGER
  LAUNDRY_STAFF
  RESORT_OWNER
  RESORT_STAFF
}

enum WorkspaceType {
  LAUNDRY
  RESORT
}

enum OnboardingStatus {
  NOT_REQUIRED
  PENDING
  COMPLETED
  BLOCKED
}

enum TenantStatus {
  PROVISIONING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum LaundryWorkspaceStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum BranchStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum TenantRole {
  OWNER
  MANAGER
  STAFF
  ACCOUNTANT
  DRIVER
}

enum TenantMembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum WorkStatus {
  DRAFT
  BAG_RECEIVED
  FACTORY_RECEIVED
  BAG_OPENED
  ITEM_COUNTED
  TYPE_SORTED
  COLOR_SORTED
  DATA_RECORDED
  RETURNED
  CLOSED
  CANCELLED
}

enum BagStatus {
  RECEIVED
  OPENED
  COUNTED
  CLOSED
}

enum MovementType {
  COUNTED_AT_LAUNDRY
  ISSUE_REPORTED
  RETURNED_TO_RESORT
  ADJUSTMENT
}

enum IssueType {
  DAMAGED
  MISSING
  COUNT_MISMATCH
  RETURN_MISMATCH
  OTHER
}

enum IssueStatus {
  OPEN
  REVIEWING
  RESOLVED
  CANCELLED
}

enum ClaimStatus {
  OPEN
  IN_REVIEW
  APPROVED
  REJECTED
  RESOLVED
}

enum IdentityProvider {
  GOOGLE
}

enum StepUpPurpose {
  LINK_IDENTITY
  UNLINK_IDENTITY
}

enum WashLoadStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum WashLoadFitStatus {
  UNCHECKED
  UNDER_LOADED
  OPTIMAL
  OVER_LOADED
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  passwordHash  String?
  displayName   String?
  role          UserRole?
  workspaceType WorkspaceType?
  onboardingStatus OnboardingStatus @default(NOT_REQUIRED)

  resortId Int?
  resort   Resort? @relation(fields: [resortId], references: [id])

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdWorks LaundryWork[] @relation("WorkCreatedBy")
  issueReports IssueReport[] @relation("IssueReportedBy")
  deviceSessions DeviceSession[]
  identities UserIdentity[]
  identityLinkIntents IdentityLinkIntent[]
  identityUnlinkIntents IdentityUnlinkIntent[]
  stepUpGrants StepUpGrant[]
  tenantMemberships TenantMembership[]
  createdTenants Tenant[] @relation("TenantCreatedBy")

  @@index([resortId])
  @@index([workspaceType])
  @@index([role])
}

model Tenant {
  id               String       @id @default(uuid())
  slug             String       @unique
  displayName      String
  legalName        String?
  timezone         String
  status           TenantStatus @default(PROVISIONING)
  createdById      Int?
  createdBy        User?        @relation("TenantCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  suspendedAt      DateTime?
  suspensionReason String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  laundryWorkspace LaundryWorkspace?
  branches         Branch[]
  memberships      TenantMembership[]

  @@index([status])
  @@index([createdById])
}

model LaundryWorkspace {
  id          String                   @id @default(uuid())
  tenantId    String                   @unique
  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status      LaundryWorkspaceStatus   @default(ACTIVE)
  displayName String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  branches Branch[]

  @@unique([id, tenantId])
  @@index([status])
}

model Branch {
  id                 String          @id @default(uuid())
  tenantId           String
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  laundryWorkspaceId String
  laundryWorkspace   LaundryWorkspace @relation(fields: [laundryWorkspaceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  code               String
  name               String
  timezone           String?
  address            String?
  isDefault          Boolean         @default(false)
  status             BranchStatus    @default(ACTIVE)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([laundryWorkspaceId])
}

model TenantMembership {
  id            String                 @id @default(uuid())
  tenantId      String
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId        Int
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          TenantRole
  status        TenantMembershipStatus @default(PENDING)
  version       Int                    @default(1)
  positionTitle String?
  activatedAt   DateTime?
  suspendedAt   DateTime?
  revokedAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([tenantId, userId])
  @@index([userId, status])
  @@index([tenantId, status, role])
}

model UserIdentity {
  id              String           @id @default(uuid())
  userId          Int
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        IdentityProvider
  providerSubject String
  providerEmail   String?
  emailVerified   Boolean          @default(false)
  displayName     String?
  avatarUrl       String?
  linkedAt        DateTime         @default(now())
  lastUsedAt      DateTime?
  unlinkedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  unlinkIntents   IdentityUnlinkIntent[]

  @@unique([provider, providerSubject])
  @@index([userId])
  @@index([providerEmail])
  @@index([unlinkedAt])
}

model IdentityLinkIntent {
  id              String           @id @default(uuid())
  userId          Int
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        IdentityProvider
  providerSubject String
  providerEmail   String?
  emailVerified   Boolean          @default(false)
  displayName     String?
  avatarUrl       String?
  sessionContext  String
  attemptCount    Int              @default(0)
  createdAt       DateTime         @default(now())
  expiresAt       DateTime
  confirmedAt     DateTime?
  consumedAt      DateTime?
  cancelledAt     DateTime?
  supersededAt    DateTime?

  @@index([userId])
  @@index([provider, providerSubject])
  @@index([expiresAt])
}

model StepUpGrant {
  id             String        @id @default(uuid())
  userId         Int
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose        StepUpPurpose
  targetId       String
  secretHash     String
  sessionContext String
  createdAt      DateTime      @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?

  @@index([userId])
  @@index([purpose, targetId])
  @@index([expiresAt])
}

model IdentityUnlinkIntent {
  id             String       @id @default(uuid())
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  identityId     String
  identity       UserIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  sessionContext String
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  consumedAt     DateTime?
  cancelledAt    DateTime?

  @@index([userId])
  @@index([identityId])
  @@index([expiresAt])
}

model DeviceSession {
  id                String   @id @default(uuid())
  userId            Int
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId          String
  credentialHash    String
  previousHash      String?
  rotationCounter   Int      @default(0)
  deviceLabel       String?
  userAgent         String?
  createdAt         DateTime @default(now())
  lastUsedAt        DateTime @default(now())
  idleExpiresAt     DateTime
  absoluteExpiresAt DateTime
  revokedAt         DateTime?
  compromisedAt     DateTime?

  @@index([userId])
  @@index([familyId])
  @@index([idleExpiresAt])
  @@index([absoluteExpiresAt])
  @@index([revokedAt])
}

model Resort {
  id           Int     @id @default(autoincrement())
  name         String
  contactName  String?
  contactPhone String?
  address      String?
  active       Boolean @default(true)

  users      User[]
  works      LaundryWork[]
  bags       LaundryBag[]
  countLines LaundryCountLine[]
  movements  LinenMovement[]
  inventory  LinenInventorySummary[]
  issues     IssueReport[]
  workImages LaundryWorkImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model LaundryItemType {
  id               Int      @id @default(autoincrement())
  name             String
  category         String?
  weightPerPieceKg Decimal? @db.Decimal(6, 3)
  active           Boolean  @default(true)

  countLines LaundryCountLine[]
  movements  LinenMovement[]
  inventory  LinenInventorySummary[]
  issues     IssueReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, category])
  @@index([active])
}

model LaundryWork {
  id     Int    @id @default(autoincrement())
  workNo String @unique

  resortId Int
  resort   Resort @relation(fields: [resortId], references: [id])

  bagCount      Int        @default(0)
  currentStatus WorkStatus @default(DRAFT)
  issueCount    Int        @default(0)

  receivedDate DateTime?
  returnedAt   DateTime?
  closedAt     DateTime?

  createdById Int?
  createdBy   User? @relation("WorkCreatedBy", fields: [createdById], references: [id])

  bags          LaundryBag[]
  countLines    LaundryCountLine[]
  movements     LinenMovement[]
  issues        IssueReport[]
  images        LaundryWorkImage[]
  statusLogs    WorkStatusLog[]
  washLoadPlans WashLoadPlan[]

  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resortId])
  @@index([currentStatus])
  @@index([receivedDate])
  @@index([returnedAt])
  @@index([closedAt])
}

model LaundryBag {
  id Int @id @default(autoincrement())

  workId Int
  work   LaundryWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  resortId Int
  resort   Resort @relation(fields: [resortId], references: [id])

  bagNo  String
  status BagStatus @default(RECEIVED)

  receivedAt DateTime?
  openedAt   DateTime?
  note       String?

  countLines LaundryCountLine[]
  issues     IssueReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workId, bagNo])
  @@index([resortId])
  @@index([status])
  @@index([receivedAt])
  @@index([openedAt])
}

model LaundryCountLine {
  id Int @id @default(autoincrement())

  workId Int
  work   LaundryWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  bagId Int?
  bag   LaundryBag? @relation(fields: [bagId], references: [id])

  resortId Int
  resort   Resort @relation(fields: [resortId], references: [id])

  itemTypeId Int
  itemType   LaundryItemType @relation(fields: [itemTypeId], references: [id])

  colorGroup    String?
  quantity      Int     @default(0)
  issueQuantity Int     @default(0)
  note          String?

  issues IssueReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([bagId])
  @@index([resortId])
  @@index([itemTypeId])
  @@index([colorGroup])
}

model LinenMovement {
  id Int @id @default(autoincrement())

  resortId Int
  resort   Resort @relation(fields: [resortId], references: [id])

  workId Int?
  work   LaundryWork? @relation(fields: [workId], references: [id])

  itemTypeId Int
  itemType   LaundryItemType @relation(fields: [itemTypeId], references: [id])

  colorGroup   String?
  movementType MovementType
  quantity     Int

  occurredAt DateTime @default(now())
  note       String?

  @@index([resortId])
  @@index([workId])
  @@index([itemTypeId])
  @@index([colorGroup])
  @@index([movementType])
  @@index([occurredAt])
}

model LinenInventorySummary {
  id Int @id @default(autoincrement())

  resortId Int
  resort   Resort @relation(fields: [resortId], references: [id])

  itemTypeId Int
  itemType   LaundryItemType @relation(fields: [itemTypeId], references: [id])

  colorGroup String?

  totalKnownQty Int @default(0)
  atResortQty   Int @default(0)
  atLaundryQty  Int @default(0)
  issueQty      Int @default(0)
  returnedQty   Int @default(0)

  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([resortId, itemTypeId, colorGroup])
  @@index([resortId])
  @@index([itemTypeId])
  @@index([colorGroup])
}

model IssueReport {
  id Int @id @default(autoincrement())

  workId Int
  work   LaundryWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  resortId Int
  resort   Resort @relation(fields: [resortId], references: [id])

  bagId Int?
  bag   LaundryBag? @relation(fields: [bagId], references: [id], onDelete: SetNull)

  countLineId Int?
  countLine   LaundryCountLine? @relation(fields: [countLineId], references: [id], onDelete: SetNull)

  itemTypeId Int?
  itemType   LaundryItemType? @relation(fields: [itemTypeId], references: [id])

  colorGroup  String?
  issueType   IssueType
  quantity    Int         @default(0)
  description String?
  status      IssueStatus @default(OPEN)

  reportedById Int?
  reportedBy   User? @relation("IssueReportedBy", fields: [reportedById], references: [id])

  reportedAt DateTime  @default(now())
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  claim LaundryClaim?

  @@index([workId])
  @@index([resortId])
  @@index([bagId])
  @@index([countLineId])
  @@index([itemTypeId])
  @@index([colorGroup])
  @@index([status])
  @@index([reportedAt])
}

model LaundryClaim {
  id Int @id @default(autoincrement())

  issueId Int         @unique
  issue   IssueReport @relation(fields: [issueId], references: [id], onDelete: Cascade)

  status         ClaimStatus @default(OPEN)
  claimReason    String
  reviewNote     String?
  resolutionNote String?

  createdById  Int?
  reviewedById Int?
  resolvedById Int?
  reviewedAt   DateTime?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model LaundryWorkImage {
  id Int @id @default(autoincrement())

  workId Int
  work   LaundryWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  resortId Int
  resort   Resort @relation(fields: [resortId], references: [id])

  url          String
  publicId     String?
  provider     String  @default("LOCAL")
  mimeType     String?
  originalName String?
  sizeBytes    Int?

  caption      String?
  displayOrder Int     @default(0)
  isCover      Boolean @default(false)

  uploadedById Int?
  uploadedAt   DateTime @default(now())

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workId])
  @@index([resortId])
  @@index([isCover])
  @@index([deletedAt])
  @@index([displayOrder])
}

model WorkStatusLog {
  id Int @id @default(autoincrement())

  workId Int
  work   LaundryWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  fromStatus    WorkStatus?
  toStatus      WorkStatus
  changedById   Int?
  changedByName String?
  changedAt     DateTime    @default(now())
  note          String?

  @@index([workId])
  @@index([toStatus])
  @@index([changedAt])
}

model LaundryMachine {
  id           Int     @id @default(autoincrement())
  code         String  @unique
  name         String
  capacityKg   Decimal @db.Decimal(6, 2)
  displayOrder Int     @default(0)
  active       Boolean @default(true)

  loadRules     LaundryMachineLoadRule[]
  washLoadPlans WashLoadPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([displayOrder])
}

model LaundryMachineLoadRule {
  id Int @id @default(autoincrement())

  machineId Int
  machine   LaundryMachine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  name        String
  minWeightKg Decimal @db.Decimal(6, 2)
  targetKg    Decimal @db.Decimal(6, 2)
  maxWeightKg Decimal @db.Decimal(6, 2)

  active Boolean @default(true)

  washLoadPlans WashLoadPlan[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([machineId])
  @@index([active])
}

model WashLoadPlan {
  id Int @id @default(autoincrement())

  workId Int
  work   LaundryWork @relation(fields: [workId], references: [id], onDelete: Cascade)

  machineId Int
  machine   LaundryMachine @relation(fields: [machineId], references: [id])

  loadRuleId Int?
  loadRule   LaundryMachineLoadRule? @relation(fields: [loadRuleId], references: [id])

  loadNo              Int
  estimatedPieceCount Int
  totalWeightKg       Decimal @db.Decimal(8, 2)

  status    WashLoadStatus    @default(DRAFT)
  fitStatus WashLoadFitStatus @default(UNCHECKED)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workId, loadNo])
  @@index([workId])
  @@index([machineId])
  @@index([loadRuleId])
  @@index([status])
  @@index([fitStatus])
}
